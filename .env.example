# LogiCrisis — API Keys Configuration
# Copy this file to .env and fill in your keys.
# Zero-config APIs (no key needed): Open-Meteo, ExchangeRate-API, GDELT, World Bank
# Optional keys below add richer data.

# ── OpenWeatherMap (optional — enhances weather data) ────────────────────────
# Free: 1,000,000 calls/month | Sign up: https://openweathermap.org/api
# After signup → API keys tab → copy the default key
scaler_weather=your_openweathermap_key_here

# ── NewsAPI (optional — breaking India trade/port headlines) ─────────────────
# Free: 100 requests/day | Sign up: https://newsapi.org/register
# After signup → copy the API key from your dashboard
NEWS_API_KEY=your_key_here

# ── W&B (optional — training experiment tracking) ────────────────────────────
# Free | Sign up: https://wandb.ai → Settings → API keys
# Set REPORT_TO=wandb in training to enable
WANDB_API_KEY=your_key_here
REPORT_TO=none

# ── HuggingFace (for Space deployment and model download) ────────────────────
# Free | Get token: https://huggingface.co/settings/tokens (write access)
HF_TOKEN=your_hf_token_here
